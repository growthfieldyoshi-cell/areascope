
  const res = await fetch(url);
  if (!res.ok) throw new Error(`e-Stat API error: ${res.status}`);

  const json = await res.json();
  return toArray(json?.GET_STATS_DATA?.STATISTICAL_DATA?.DATA_INF?.VALUE);
}
async function insertPopulationRows(rows) {
  const chunkSize = 500;

  for (let i = 0; i < rows.length; i += chunkSize) {
    const chunk = rows.slice(i, i + chunkSize);
    const municipalityCodes = chunk.map((r) => r.code);
    const years = chunk.map((r) => r.year);
    const populations = chunk.map((r) => r.population);
    const sources = chunk.map(() => "e-stat");

    await sql`
      INSERT INTO municipality_populations
      (municipality_code, year, population, source)
      SELECT *
      FROM unnest(
        ${municipalityCodes}::text[],
        ${years}::int[],
        ${populations}::int[],
        ${sources}::text[]
      )
      ON CONFLICT (municipality_code, year)
      DO UPDATE SET
        population = EXCLUDED.population,
        source = EXCLUDED.source
    `;
  }
}
async function main() {
  console.log("Fetching population data from e-Stat...");
  const values = await fetchPopulation();

  const municipalities = new Set();
  const populationRows = [];
  let skipped = 0;

  for (const v of values) {
    const code = String(v["@area"] ?? "").trim();
    const time = String(v["@time"] ?? "").trim();
    const rawPopulation = String(v["$"] ?? "").trim();

    if (!isMunicipalityCode(code)) { skipped += 1; continue; }
    if (time.length < 4) { skipped += 1; continue; }

    const year = Number(time.slice(0, 4));
    if (!YEARS.has(year)) { skipped += 1; continue; }
    if (!isIntegerString(rawPopulation)) { skipped += 1; continue; }

    const population = Number(rawPopulation);
    if (!Number.isInteger(year) || !Number.isInteger(population)) {
      skipped += 1; continue;
    }

    municipalities.add(code);
    populationRows.push({ code, year, population });
  }

  console.log("municipalities:", municipalities.size);
  conso  conso  conso  conso  conso  conso  conso en  conso  conso  conso ki  conso  conso  conso  conso  conso  conso  conso enawait   conso  conso  conso  conso  conso);
  console.log("Import finished");
}
main().catch((err) => {
  console.error(err);
  process.exit(1);
});
